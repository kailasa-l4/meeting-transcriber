# API Keys
SLACK_BOT_TOKEN=xoxb-your-token-here
DEEPGRAM_API_KEY=your-deepgram-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# Slack
MEETING_CHANNEL_ID=C0XXXXXXX

# LLM Models
CHUNK_MODEL=google/gemini-2.0-flash-001
FINAL_MODEL=anthropic/claude-sonnet-4

# Meeting config
SUMMARY_INTERVAL_SECONDS=180

# Auth
JWT_SECRET=change-me-to-a-random-secret-in-production
# Username that is auto-approved on register/startup and can access /admin.
# Leave empty to disable admin access entirely.
ADMIN_USERNAME=

# Postgres (used by Docker compose; change from default for production)
POSTGRES_PASSWORD=meetings

# App DB connection. Docker compose sets this automatically — leave blank
# unless running the backend outside the compose stack.
DATABASE_URL=

# Server
PORT=8000
